[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .tox,
    .pytest_cache,
    .mypy_cache

# Error codes to ignore
ignore =
    E203,
    E501,
    W503,
    E266,
    E402

per-file-ignores =
    __init__.py:F401,F403
    tests/*:D100,D101,D102,D103,D104

max-complexity = 10
